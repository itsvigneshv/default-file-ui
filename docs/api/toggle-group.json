{
  "name": "toggle-group",
  "slug": "toggle-group",
  "title": "Toggle Group",
  "description": "Grouped options for single-select choices.",
  "chapter": "inputs",
  "registryDependencies": [
    "foundation"
  ],
  "importPath": "@default-file/ui/components/df-toggle-group",
  "dependencies": [],
  "api": {
    "description": "Grouped single- or multi-select toggles. Compose ToggleGroup and ToggleGroupItem.",
    "groups": [
      {
        "id": "toggle-group",
        "title": "ToggleGroup",
        "props": [
          {
            "name": "variant",
            "type": "\"default\" | \"outline\"",
            "default": "\"default\"",
            "description": "Visual style for items."
          },
          {
            "name": "size",
            "type": "\"default\" | \"sm\" | \"lg\"",
            "default": "\"default\"",
            "description": "Item height and type size."
          },
          {
            "name": "radius",
            "type": "\"xxs\" | \"xs\" | \"sm\" | \"md\" | \"lg\" | \"xl\" | \"2xl\" | \"3xl\" | \"4xl\" | \"full\"",
            "description": "Corner radius of the group. Defaults to a pill look."
          },
          {
            "name": "cornerShape",
            "type": "\"round\" | \"smooth\"",
            "description": "Instance corner curve. Omit to inherit --df-corner-shape from the theme (set at create/init)."
          },
          {
            "name": "spacing",
            "type": "number",
            "default": "2",
            "description": "Gap between items (design-scale units)."
          },
          {
            "name": "orientation",
            "type": "\"horizontal\" | \"vertical\"",
            "default": "\"horizontal\"",
            "description": "Layout direction."
          },
          {
            "name": "multiple",
            "type": "boolean",
            "default": "false",
            "description": "Allow more than one selected value."
          },
          {
            "name": "value",
            "type": "string[]",
            "description": "Controlled selected values."
          },
          {
            "name": "defaultValue",
            "type": "string[]",
            "default": "[]",
            "description": "Uncontrolled initial values."
          },
          {
            "name": "onValueChange",
            "type": "(value: string[]) => void",
            "description": "Called when selection changes."
          },
          {
            "name": "disabled",
            "type": "boolean",
            "default": "false",
            "description": "Disable the whole group."
          }
        ]
      },
      {
        "id": "toggle-group-item",
        "title": "ToggleGroupItem",
        "props": [
          {
            "name": "value",
            "type": "string",
            "description": "Item value (required)."
          },
          {
            "name": "variant",
            "type": "\"default\" | \"outline\"",
            "description": "Override group variant for this item."
          },
          {
            "name": "size",
            "type": "\"default\" | \"sm\" | \"lg\"",
            "description": "Override group size for this item."
          },
          {
            "name": "disabled",
            "type": "boolean",
            "description": "Non-interactive item."
          },
          {
            "name": "children",
            "type": "ReactNode",
            "description": "Item label or icon."
          }
        ]
      },
      {
        "id": "toggle-group-tokens",
        "title": "Tokens",
        "description": "Theme defaults live on :root. Override these globally or on a local host.",
        "props": [
          {
            "name": "--df-toggle-radius",
            "type": "CSS length",
            "description": "Instance variable set from the radius prop. Falls back to --radius-4xl.",
            "default": "var(--radius-4xl)"
          },
          {
            "name": "--gap",
            "type": "CSS length",
            "description": "Instance variable set from the spacing prop.",
            "default": "calc(2 * var(--spacing-unit))"
          },
          {
            "name": "--muted",
            "type": "CSS color",
            "description": "Outline variant hover fill.",
            "default": "var(--df-neutral-50)"
          },
          {
            "name": "--background",
            "type": "CSS color",
            "description": "Selected item fill.",
            "default": "var(--df-neutral-0)"
          },
          {
            "name": "--border",
            "type": "CSS color",
            "description": "Outline variant border.",
            "default": "var(--df-neutral-100)"
          },
          {
            "name": "--foreground",
            "type": "CSS color",
            "description": "Selected item label.",
            "default": "var(--df-neutral-900)"
          },
          {
            "name": "--df-corner-shape",
            "type": "CSS corner-shape",
            "description": "Theme corner curve for all kit chrome. round = circular arcs; smooth = continuous squircle. Set with df-ui init --corner-shape, or override on :root. Default round.",
            "default": "var(--df-corner-shape-round)"
          }
        ]
      }
    ]
  }
}
