{
  "name": "button",
  "slug": "button",
  "title": "Button",
  "description": "Primary actions with variants, text sizes from xs to 2xl, and matching icon sizes.",
  "chapter": "actions",
  "registryDependencies": [
    "foundation"
  ],
  "importPath": "@default-file/ui/components/df-button",
  "dependencies": [],
  "api": {
    "description": "Primary actions with variants, sizes, and optional leading or trailing content.",
    "groups": [
      {
        "id": "button",
        "title": "Button",
        "props": [
          {
            "name": "variant",
            "type": "\"default\" | \"outline\" | \"secondary\" | \"ghost\" | \"destructive\" | \"link\"",
            "default": "\"default\"",
            "description": "Visual style of the button."
          },
          {
            "name": "size",
            "type": "\"default\" | \"xs\" | \"sm\" | \"lg\" | \"xl\" | \"2xl\" | \"icon\" | \"icon-xs\" | \"icon-sm\" | \"icon-lg\" | \"icon-xl\" | \"icon-2xl\"",
            "default": "\"default\"",
            "description": "Text sizes use padding (xs to 2xl). Icon sizes are square controls (icon-xs to icon-2xl). Leading and trailing work on every text size, including xs."
          },
          {
            "name": "underline",
            "type": "boolean",
            "default": "true",
            "description": "Link variant only. When true, show underline on hover. Set false to keep the label plain on hover."
          },
          {
            "name": "leading",
            "type": "ReactNode",
            "description": "Content before the label, such as an icon."
          },
          {
            "name": "trailing",
            "type": "ReactNode",
            "description": "Content after the label, such as an icon or badge."
          },
          {
            "name": "disabled",
            "type": "boolean",
            "description": "Disables the button."
          },
          {
            "name": "className",
            "type": "string",
            "description": "Additional styles."
          },
          {
            "name": "…button attributes",
            "type": "ButtonHTMLAttributes",
            "description": "Native button props (type, onClick, aria-label, etc.)."
          }
        ]
      },
      {
        "id": "button-helpers",
        "title": "Helpers",
        "description": "Class helper for applying button styles to a host that is not a button.",
        "props": [
          {
            "name": "dfButtonClass",
            "type": "(opts?: { variant?, size?, className? }) => string",
            "description": "Builds the same class string Button uses internally. For link hosts, set data-underline to hover or none to match the underline prop."
          }
        ]
      },
      {
        "id": "button-tokens",
        "title": "Tokens",
        "description": "Theme defaults live on :root. Override these globally or on a local host.",
        "props": [
          {
            "name": "--spacing-unit",
            "type": "CSS length",
            "description": "Base unit for padding, gap, and icon button size.",
            "default": "0.25rem"
          },
          {
            "name": "--primary",
            "type": "CSS color",
            "description": "Default variant fill.",
            "default": "var(--df-neutral-850, var(--df-neutral-900))"
          },
          {
            "name": "--primary-foreground",
            "type": "CSS color",
            "description": "Default variant label.",
            "default": "var(--df-neutral-0)"
          },
          {
            "name": "--secondary",
            "type": "CSS color",
            "description": "Secondary variant fill.",
            "default": "var(--df-neutral-50)"
          },
          {
            "name": "--secondary-foreground",
            "type": "CSS color",
            "description": "Secondary variant label.",
            "default": "var(--df-neutral-850, var(--df-neutral-900))"
          },
          {
            "name": "--destructive",
            "type": "CSS color",
            "description": "Destructive variant fill.",
            "default": "oklch(0.577 0.245 27.325)"
          },
          {
            "name": "--border",
            "type": "CSS color",
            "description": "Outline variant border.",
            "default": "var(--df-neutral-100)"
          },
          {
            "name": "--muted",
            "type": "CSS color",
            "description": "Ghost variant hover fill.",
            "default": "var(--df-neutral-50)"
          },
          {
            "name": "--ring",
            "type": "CSS color",
            "description": "Focus ring color.",
            "default": "var(--df-neutral-400)"
          },
          {
            "name": "--df-press-offset",
            "type": "CSS length",
            "description": "Active press translate distance.",
            "default": "1px"
          },
          {
            "name": "--df-underline-offset",
            "type": "CSS length",
            "description": "Link variant underline offset.",
            "default": "4px"
          },
          {
            "name": "--radius-4xl",
            "type": "CSS length",
            "description": "Default corner radius.",
            "default": "calc(var(--radius) * 2.6)"
          },
          {
            "name": "--df-corner-shape",
            "type": "CSS corner-shape",
            "description": "Theme corner curve for all kit chrome. round = circular arcs; smooth = continuous squircle. Set with df-ui init --corner-shape, or override on :root. Default round.",
            "default": "var(--df-corner-shape-round)"
          }
        ]
      }
    ]
  }
}
