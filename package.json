{
  "name": "@default-file/ui",
  "version": "0.1.0",
  "description": "Default File UI design system: color system, tokens, components, motion, CLI, and copy-source registry.",
  "license": "MIT",
  "author": "Vignesh V",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsvigneshv/default-file-ui.git"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "bin": {
    "default-file-ui": "./bin/default-file-ui.mjs",
    "df-ui": "./bin/default-file-ui.mjs"
  },
  "files": [
    "bin",
    "src",
    "public/r",
    "registry.json",
    "scripts",
    "docs",
    "skills"
  ],
  "exports": {
    "./css/df-color-system.css": "./src/css/df-color-system.css",
    "./css/df-index.css": "./src/css/df-index.css",
    "./css/*": "./src/css/*",
    "./components": "./src/components/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks": "./src/hooks/index.ts",
    "./utils": "./src/lib/utils.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "df:colors": "node scripts/generate-df-color-scales.mjs",
    "df:utilities": "node scripts/generate-df-utilities.mjs",
    "df:breakpoints": "node scripts/generate-df-breakpoints.mjs",
    "df:tokens": "npm run df:colors && npm run df:utilities && npm run df:breakpoints",
    "df:registry": "node scripts/build-df-registry.mjs",
    "df:cli": "node bin/default-file-ui.mjs",
    "df:mcp": "node bin/default-file-ui.mjs mcp",
    "test:discovery": "node scripts/cli/test-discovery.mjs",
    "prepublishOnly": "npm run df:tokens && npm run df:registry"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "rough-notation": ">=0.5.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "rough-notation": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "rough-notation": "^0.5.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
